{
    "name": "maosiji/luphp",
    "description": "更快的做一些 PHP、WordPress 的开发",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "MAOSIJI\\LU\\": "src/original",
            "MAOSIJI\\LU\\EXCEPTION\\": "src/exception",
            "MAOSIJI\\LU\\WP\\": "src/wordpress",
            "MAOSIJI\\LU\\WP\\SQL\\": "src/wordpress/sql"
        },
        "files":[
            "src/compat/up.php"
        ],
        "exclude-from-classmap": [
            "src/original/LUSend.php",
            "src/wordpress/LUWPSend.php",
            "src/original/LUSession.php",
            "src/original/LUSafe.php"
        ]
    },
    "extra": {
        "deprecated": {}
    },
    "authors": [
        {
            "name": "maosiji",
            "email": "1394846666@qq.com",
            "homepage": "https://www.maosiji.com",
            "role": "二维程序员 "
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "php": "^7.0",
        "ext-json": "*",
        "ext-curl": "*",
        "ext-ctype": "*",
        "ext-openssl": "*",
        "ext-fileinfo": "*"
    }
}
